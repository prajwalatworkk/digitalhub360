# SMTP configuration
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_user
SMTP_PASS=your_password

# Email routing
MAIL_TO=info@digitalhub360.in
MAIL_FROM=DigitalHub360 <info@digitalhub360.in>

# Google Sheets webhook (Apps Script or Sheet API proxy)
SHEET_WEBHOOK_URL=https://script.google.com/macros/s/your-script-id/exec
